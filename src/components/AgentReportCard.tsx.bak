'use client';

import React from 'react';
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '@/components/ui/card';
import { AgentReport } from '@/lib/scraper/types';
import { Tabs, TabsContent, TabsList, TabsTrigger } from "@/components/ui/tabs";
import { Badge } from '@/components/ui/badge';
import { CheckCircle, XCircle } from 'lucide-react';
import ReferenceArcheology from '@/components/ReferenceArcheology';

interface AnalyzedAccountData {
  profile: any;
  posts: any[];
  visuals: any;
  captions: any;
}

interface Props {
  report: AgentReport;
  analyzedData?: AnalyzedAccountData[];
  failedAccounts?: string[];
}

function SwotCell({ title, items, color }: { title: string; items?: string[]; color: string }) {
  return (
    <div className={`p-5 rounded-2xl border ${color} shadow-sm backdrop-blur-sm transition-transform hover:-translate-y-1 duration-300`}>
      <p className="text-xs font-bold uppercase tracking-wider mb-3 opacity-80">{title}</p>
      <ul className="space-y-2">
        {items?.map((s, i) => (
          <li key={i} className="text-sm flex gap-2 items-start font-medium">
            <span className="mt-1.5 w-1.5 h-1.5 rounded-full bg-current shrink-0 opacity-60 shadow-sm" />
            {s}
          </li>
        ))}
      </ul>
    </div>
  );
}

function PatternItem({ index, text, color }: { index: number; text: string; color: string }) {
  return (
    <li className="flex gap-4 items-start">
      <span className={`shrink-0 flex items-center justify-center w-7 h-7 rounded-full ${color} font-bold text-sm`}>
        {index}
      </span>
      <span className="text-sm text-foreground leading-relaxed pt-0.5">{text}</span>
    </li>
  );
}

export default function AgentReportCard({ report, analyzedData = [], failedAccounts = [] }: Props) {
  if (!report) return null;



  return (
    <div className="space-y-4 animate-in fade-in slide-in-from-bottom-4 duration-500 w-full">

      {/* 분석 현황 뱃지 */}
      {(analyzedData.length > 0 || failedAccounts.length > 0) && (
        <div className="flex flex-wrap gap-2 items-center">
          <span className="text-xs text-muted-foreground">분석 현황:</span>
          <Badge variant="default" className="gap-1 text-xs">
            <CheckCircle className="w-3 h-3" />
            {analyzedData.length}개 성공
          </Badge>
          {failedAccounts.length > 0 && (
            <Badge variant="destructive" className="gap-1 text-xs">
              <XCircle className="w-3 h-3" />
              {failedAccounts.length}개 실패
            </Badge>
          )}
          {failedAccounts.length > 0 && (
            <span className="text-xs text-muted-foreground truncate">
              실패: {failedAccounts.join(', ')}
            </span>
          )}
        </div>
      )}

      {/* 요약 헤더 */}
      <div className="p-6 sm:p-8 rounded-[2rem] border border-primary/20 bg-gradient-to-br from-primary/10 via-background to-background relative overflow-hidden group shadow-xl mb-6 mt-4">
        <div className="absolute top-0 right-0 w-64 h-64 bg-primary/20 blur-[80px] rounded-full pointer-events-none -mt-20 -mr-20 group-hover:bg-primary/30 transition-colors duration-700" />
        <div className="relative z-10">
          <p className="text-[11px] font-bold uppercase tracking-widest text-primary mb-3">트렌드 종합 요약</p>
          <p className="text-base sm:text-lg leading-relaxed text-foreground/90 font-medium">{report.summary}</p>
        </div>
      </div>

      <Tabs defaultValue="summary" className="w-full">
        <TabsList className="grid w-full grid-cols-5 h-12 p-1 bg-muted/50 rounded-2xl border border-border/50 backdrop-blur-sm mb-6">
          <TabsTrigger value="summary" className="text-sm rounded-xl data-[state=active]:bg-background data-[state=active]:shadow-md transition-all duration-300">📊 종합</TabsTrigger>
          <TabsTrigger value="visual" className="text-sm rounded-xl data-[state=active]:bg-background data-[state=active]:shadow-md transition-all duration-300">📸 비주얼</TabsTrigger>
          <TabsTrigger value="caption" className="text-sm rounded-xl data-[state=active]:bg-background data-[state=active]:shadow-md transition-all duration-300">✍️ 캡션</TabsTrigger>
          <TabsTrigger value="accounts" className="text-sm rounded-xl data-[state=active]:bg-background data-[state=active]:shadow-md transition-all duration-300">👥 계정</TabsTrigger>
          <TabsTrigger value="action" className="text-sm rounded-xl data-[state=active]:bg-background data-[state=active]:shadow-md transition-all duration-300">🎯 전략</TabsTrigger>
        </TabsList>

        {/* ── 종합 탭 ── */}
        <TabsContent value="summary" className="mt-4 space-y-4">
          {/* 핵심 패턴 */}
          <Card>
            <CardHeader className="pb-3">
              <CardTitle className="text-base">핵심 공통 패턴</CardTitle>
              <CardDescription>여러 계정을 가로질러 공통적으로 관찰된 흐름</CardDescription>
            </CardHeader>
            <CardContent>
              <ul className="space-y-3">
                {report.keyPatterns?.map((p, i) => (
                  <PatternItem key={i} index={i + 1} text={p}
                    color="bg-indigo-100 text-indigo-600 dark:bg-indigo-900/30 dark:text-indigo-400"
                  />
                ))}
              </ul>
            </CardContent>
          </Card>

          {/* SWOT */}
          {report.swot && (
            <div className="col-span-1 md:col-span-12 p-6 sm:p-8 rounded-[2rem] border border-border/50 bg-card shadow-lg mt-4">
              <h3 className="text-xl font-bold tracking-tight mb-6 flex items-center gap-2">
                <span className="w-8 h-8 rounded-xl bg-primary/10 flex items-center justify-center text-primary text-sm">💡</span>
                트렌드 SWOT 분석
              </h3>
              <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
                <SwotCell title="강점 (STRENGTHS)" items={report.swot.strengths}
                  color="bg-emerald-500/10 border-emerald-500/20 text-emerald-600 dark:text-emerald-400" />
                <SwotCell title="약점 (WEAKNESSES)" items={report.swot.weaknesses}
                  color="bg-rose-500/10 border-rose-500/20 text-rose-600 dark:text-rose-400" />
                <SwotCell title="기회 (OPPORTUNITIES)" items={report.swot.opportunities}
                  color="bg-sky-500/10 border-sky-500/20 text-sky-600 dark:text-sky-400" />
                <SwotCell title="위협 (THREATS)" items={report.swot.threats}
                  color="bg-amber-500/10 border-amber-500/20 text-amber-600 dark:text-amber-400" />
              </div>
            </div>
          )}
        </TabsContent>

        {/* ── 비주얼 트렌드 탭 ── */}
        <TabsContent value="visual" className="mt-4">
          <Card>
            <CardHeader className="pb-3">
              <CardTitle className="text-base">비주얼 트렌드</CardTitle>
              <CardDescription>피드 색감, 콘텐츠 유형, 그리드 전략의 공통 패턴</CardDescription>
            </CardHeader>
            <CardContent>
              <ul className="space-y-3">
                {report.visualTrends?.map((t, i) => (
                  <PatternItem key={i} index={i + 1} text={t}
                    color="bg-orange-100 text-orange-600 dark:bg-orange-900/30 dark:text-orange-400"
                  />
                ))}
              </ul>
            </CardContent>
          </Card>
        </TabsContent>

        {/* ── 캡션 트렌드 탭 ── */}
        <TabsContent value="caption" className="mt-4">
          <Card>
            <CardHeader className="pb-3">
              <CardTitle className="text-base">캡션 트렌드</CardTitle>
              <CardDescription>화법, 주제, 해시태그, 훅 전략의 공통 패턴</CardDescription>
            </CardHeader>
            <CardContent>
              <ul className="space-y-3">
                {report.captionTrends?.map((t, i) => (
                  <PatternItem key={i} index={i + 1} text={t}
                    color="bg-violet-100 text-violet-600 dark:bg-violet-900/30 dark:text-violet-400"
                  />
                ))}
              </ul>
            </CardContent>
          </Card>
        </TabsContent>

        {/* ── 레퍼런스 계정 탭 ── */}
        <TabsContent value="accounts" className="mt-4">
          <ReferenceArcheology analyzedData={analyzedData} />
        </TabsContent>

        {/* ── 액션 플랜 탭 ── */}
        <TabsContent value="action" className="mt-4 space-y-4">
          <Card>
            <CardHeader className="pb-3">
              <CardTitle className="text-base">🚀 실행 전략</CardTitle>
              <CardDescription>이 트렌드를 활용하기 위한 구체적 액션</CardDescription>
            </CardHeader>
            <CardContent>
              <ul className="space-y-3">
                {report.recommendations?.map((rec, idx) => (
                  <li key={idx} className="flex gap-3 items-start p-4 rounded-xl border bg-green-50/50 dark:bg-green-950/10 border-green-100 dark:border-green-900/30">
                    <span className="shrink-0 flex items-center justify-center w-6 h-6 rounded-full bg-green-100 dark:bg-green-900/40 text-green-600 font-bold text-xs">
                      {idx + 1}
                    </span>
                    <span className="text-sm leading-relaxed">{rec}</span>
                  </li>
                ))}
              </ul>
            </CardContent>
          </Card>

          {report.limitations && (
            <Card className="bg-orange-50/50 dark:bg-orange-950/10 border-orange-200 dark:border-orange-900/30">
              <CardHeader className="pb-2">
                <CardTitle className="text-sm text-orange-700 dark:text-orange-400">⚠️ 분석 한계점</CardTitle>
              </CardHeader>
              <CardContent>
                <p className="text-sm text-orange-800/80 dark:text-orange-300/80 leading-relaxed">{report.limitations}</p>
              </CardContent>
            </Card>
          )}
        </TabsContent>
      </Tabs>
    </div>
  );
}
